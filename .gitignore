# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Testing / typing / linting caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Data: raw is immutable input, processed is regenerable — neither belongs in git
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Embedding caches (large, regenerable)
*.npy
*.pt
embeddings_cache/

# Notebooks
.ipynb_checkpoints/

# OS / editor
.DS_Store
.idea/
.vscode/
